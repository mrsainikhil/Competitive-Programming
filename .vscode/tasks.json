{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile C++",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "g++ -std=c++17 -O2 \"${file}\" -o \"${fileDirname}\\${fileBasenameNoExtension}.exe\""
      ],
      "problemMatcher": []
    },
    {
      "label": "Run C++",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "\"${fileDirname}\\${fileBasenameNoExtension}.exe\" <\"${fileDirname}\\input.txt\" >\"${fileDirname}\\output.txt\""
      ],
      "dependsOn": "Compile C++",
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}